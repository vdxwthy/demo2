<Page x:Class="demoExam.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Заказы"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <Button x:Name="BackButton" Content="Назад" HorizontalAlignment="Left" Padding="10,2" Click="BackButton_Click"/>
            <TextBlock Text="Список заказов" FontSize="20" FontWeight="Bold" Margin="0,10,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <ListView x:Name="OrdersList" Grid.Row="1" Margin="10" HorizontalContentAlignment="Stretch">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Background" Value="{StaticResource MainBackground}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="0">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="{Binding Code, StringFormat={}Артикул заказа: {0}}" FontWeight="Bold" FontSize="14"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Статус заказа: "/>
                                    <TextBlock Text="{Binding StatusOrder}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Адрес пункта выдачи: "/>
                                    <TextBlock Text="{Binding PickupAddress}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Дата заказа: "/>
                                    <TextBlock Text="{Binding DateOrder, StringFormat=dd.MM.yyyy}"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Margin="10" Padding="10" VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Дата доставки" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DateDelivery, StringFormat=dd.MM.yyyy}" FontSize="16" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
