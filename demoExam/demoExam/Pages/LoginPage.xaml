<Page x:Class="demoExam.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Вход">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Width="420" Padding="20" CornerRadius="8" Background="{StaticResource MainBackground}"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Email" Margin="0,5,0,2"/>
                <TextBox x:Name="EmailTextBox" Height="32"/>
                <TextBlock Text="Пароль" Margin="0,12,0,2"/>
                <PasswordBox x:Name="PasswordBox" Height="32"/>
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Войти" Width="120" Height="32" Click="LoginButton_Click"/>
                    <Button Content="Просмотр как гость" Width="180" Height="32" Margin="12,0,0,0" Click="GuestButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="ErrorText" Foreground="Crimson" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
